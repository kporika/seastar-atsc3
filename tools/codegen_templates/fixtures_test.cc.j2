std::vector<std::byte> from_hex(const char *hex) {
    std::vector<std::byte> out;
    while (*hex) {
        if (*hex == ' ' || *hex == '\t' || *hex == '\n' || *hex == '\r') {
            ++hex;
            continue;
        }
        unsigned v = 0;
        if (std::sscanf(hex, "%2x", &v) != 1) {
            return {};
        }
        out.push_back(static_cast<std::byte>(v));
        hex += 2;
    }
    return out;
}

std::string to_compact_json(const rapidjson::Value &v) {
    rapidjson::StringBuffer buf;
    rapidjson::Writer<rapidjson::StringBuffer> w(buf);
    v.Accept(w);
    return std::string(buf.GetString(), buf.GetSize());
}

std::string to_hex_str(std::span<const std::byte> b) {
    std::string s;
    s.reserve(b.size() * 2);
    char buf[3];
    for (auto x : b) {
        std::snprintf(buf, sizeof(buf), "%02X", static_cast<unsigned>(x));
        s.append(buf, 2);
    }
    return s;
}

bool field_matches(const rapidjson::Value &got, const rapidjson::Value &exp);

bool array_matches(const rapidjson::Value &got, const rapidjson::Value &exp) {
    if (!got.IsArray() || !exp.IsArray()) return false;
    if (got.Size() != exp.Size()) return false;
    for (rapidjson::SizeType i = 0; i < got.Size(); ++i) {
        const auto &g = got[i];
        const auto &e = exp[i];
        if (g.IsObject() && e.IsObject()) {
            for (auto it = e.MemberBegin(); it != e.MemberEnd(); ++it) {
                const char *k = it->name.GetString();
                if (!g.HasMember(k) || !field_matches(g[k], it->value)) {
                    return false;
                }
            }
        } else if (!field_matches(g, e)) {
            return false;
        }
    }
    return true;
}

bool field_matches(const rapidjson::Value &got, const rapidjson::Value &exp) {
    if (got.IsString() && exp.IsString()) {
        return std::strcmp(got.GetString(), exp.GetString()) == 0;
    }
    if (got.IsBool() && exp.IsBool()) {
        return got.GetBool() == exp.GetBool();
    }
    if (got.IsNumber() && exp.IsNumber()) {
        return got.GetDouble() == exp.GetDouble();
    }
    if (got.IsArray() && exp.IsArray()) {
        return array_matches(got, exp);
    }
    return false;
}

